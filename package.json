{
  "name": "tiktok-downloader-platform",
  "private": true,
  "version": "1.0.0",
  "description": "High-traffic TikTok downloader platform with Next.js, Expo and Firebase Functions.",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "build:functions": "npm --prefix functions run build",
    "serve:functions": "npm --prefix functions run serve",
    "test:functions": "npm --prefix functions run test",
    "build:shared": "npm --workspace packages/shared run build",
    "vercel-build": "npm run build:shared && npm run build:web",
    "build": "npm run build:shared && npm run build:web && npm run build:functions"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cssesc": "^3.0.0"
  },
  "devDependencies": {
    "napi-postinstall": "^0.3.4"
  }
}
